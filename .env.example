# Storage
STORAGE_ROOT=/data/podclean

# Application — set to the IP/hostname where this stack is reachable
APP_BASE_URL=http://192.168.1.x:8000

# Anthropic (optional — required only when llm_backend=cloud)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Set to 0 to force Ollama to CPU; unset or 99 to use all GPU layers
# OLLAMA_NUM_GPU=0

# Feed poll cron schedule
FEED_POLL_SCHEDULE=*/30 * * * *

# Redis
REDIS_URL=redis://redis:6379/0

# Device mode for local AI inference: auto | gpu_required | cpu_only
DEVICE_MODE=auto
